# Precedent — environment template. Copy to .env and fill from your OWN secrets.
# NEVER commit .env. Open-weight only — no closed-vendor keys belong in the runtime.

# --- Venice (open-weight inference; the ONLY model backend) ---
VENICE_API_KEY=your-venice-key
VENICE_BASE_URL=https://api.venice.ai/api/v1
PRECEDENT_MODEL_BACKEND=venice            # or "local" for the Ollama fallback profile
# Pinned open-weight model ids live in precedent/models.py — do NOT set model ids here.
VENICE_EMBED_MODEL=text-embedding-bge-m3
# PRECEDENT_DEV_MODELS=                    # leave UNSET — dev-only proprietary escape hatch, never in demo/CI

# --- Jira Service Management (live ACL source of truth) ---
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=MEDIA
JIRA_SERVICE_DESK_ID=1
JIRA_INCIDENT_REQUEST_TYPE_ID=16
JIRA_RIGHTS_OPS_ROLE_ID=10007
JIRA_SCHEDULING_OPS_ROLE_ID=10008
JIRA_ISSUE_SECURITY_SCHEME_ID=10000
JIRA_SECURITY_LEVEL_RIGHTS_OPS=10000
JIRA_SECURITY_LEVEL_SCHEDULING_OPS=10001
# JIRA_RIGHTS_OPS_ACCOUNT_ID=             # fill after inviting the 2nd agent seat
# JIRA_SCHEDULING_OPS_ACCOUNT_ID=

# --- Fetch.ai (Agentverse mailbox agents + ASI:One) ---
AGENTVERSE_API_KEY=your-agentverse-key
ASI_ONE_API_KEY=your-asi-one-key
ASI_ONE_BASE_URL=https://api.asi1.ai/v1
FETCH_AGENT_MAILBOX_KEY=
WATCHER_AGENT_SEED=
LIBRARIAN_AGENT_SEED=
OPERATOR_AGENT_SEED=
# Addresses / profile URLs / shared-chat URL are filled after registration.

# --- Kaggle (CC0 catalog data; optional — manual CSV download also works) ---
KAGGLE_USERNAME=
KAGGLE_KEY=
